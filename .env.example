# Django Configuration
DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production
DATABASE_URL=postgresql://postgres:postgres@db:5432/trackroute

# Token Encryption
TOKEN_ENCRYPTION_KEY=your-token-encryption-key-here

# Yandex AI Studio Configuration
# Required format: full model URI
# Example: gpt://b1g1234567890abcdef123/yandexgpt-lite/latest
YANDEX_MODEL=gpt://your-catalog-or-folder-id/yandexgpt-lite/latest
